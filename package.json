{
  "name": "plantuml-preview",
  "displayName": "PlantUML Preview",
  "description": "A Live PlantUML Preview using browser scripts.",
  "publisher": "hudy9x",
  "version": "1.0.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/hudy9x/vscode-ext-plantuml"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "plantuml",
        "extensions": [
          ".puml",
          ".pu",
          ".plantuml"
        ],
        "aliases": [
          "PlantUML"
        ]
      }
    ],
    "commands": [
      {
        "command": "plantuml-preview.start",
        "title": "PlantUML: Open Live Preview",
        "icon": "$(open-preview)"
      },
      {
        "command": "plantuml-preview.stat",
        "title": "PlantUML: Open Live Preview (Alias)",
        "icon": "$(open-preview)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "plantuml-preview.start",
          "when": "editorLangId == plantuml",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build": "mkdir -p build && rm -rf build/* && commit-and-tag-version && vsce package -o build/",
    "release": "commit-and-tag-version"
  },
  "devDependencies": {
    "@types/node": "18.x",
    "@types/vscode": "^1.80.0",
    "commit-and-tag-version": "^12.7.1",
    "typescript": "^5.1.3"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2"
  }
}
